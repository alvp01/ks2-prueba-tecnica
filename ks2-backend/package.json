{
  "name": "ks2-backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:ensure": "node scripts/ensureDatabase.js",
    "db:reset": "node scripts/resetDatabase.js && npm run migrate && npm run seed",
    "migrate": "npm run db:ensure && sequelize-cli db:migrate --config config/config.cjs --env development --migrations-path migrations",
    "migrate:undo": "sequelize-cli db:migrate:undo --config config/config.cjs --env development --migrations-path migrations",
    "migrate:status": "sequelize-cli db:migrate:status --config config/config.cjs --env development --migrations-path migrations",
    "seed": "sequelize-cli db:seed:all --config config/config.cjs --env development --seeders-path seeders",
    "seed:undo": "sequelize-cli db:seed:undo:all --config config/config.cjs --env development --seeders-path seeders"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "sequelize-cli": "^6.6.5"
  }
}